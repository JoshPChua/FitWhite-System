# FitWhite Aesthetics System — Environment Variables
# ─────────────────────────────────────────────────────
# Copy to .env.local and fill in your actual key values.
# Get these from: Supabase Dashboard → Settings → API

# Public (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://cdtmufbsexzlgucmlols.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Secret — server-side only. Used by API routes + seed script.
# NEVER commit .env.local to git.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Phase 3: Branch Restriction ──────────────────────────────
# Set to "true" to restrict the entire UI and all API routes to the
# Imus branch (code = 'IMS'). All other branches are hidden from the
# UI and rejected at the API level with a 403.
# Set to "false" (or omit) to run in full multi-branch mode.
NEXT_PUBLIC_IMUS_ONLY=true

# ─── Phase 3: Feature Toggles ─────────────────────────────────
# Each Phase 3 module can be toggled independently.
# Default: all are ENABLED (set to "false" to disable a module).

# Patient Package / Session tracking + A/R installment payments
NEXT_PUBLIC_ENABLE_PATIENT_PACKAGES=true

# Shift / Cash Drawer management
NEXT_PUBLIC_ENABLE_SHIFTS=true

# Doctor Commission tracking
NEXT_PUBLIC_ENABLE_DOCTOR_COMMISSIONS=true

# Service BOM — auto-deduct consumables at checkout
NEXT_PUBLIC_ENABLE_SERVICE_BOM=true
